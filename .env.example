# Copy this file to .env and fill in real values. Never commit .env.

# --- Postgres ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=financial_assistant
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# --- Google Gemini (AI Studio) ---
GEMINI_API_KEY=your_api_key_from_aistudio_google_com

# --- AWS (for SageMaker + Bedrock) ---
AWS_ACCESS_KEY_ID=your_aws_key
AWS_SECRET_ACCESS_KEY=your_aws_secret
AWS_REGION=us-east-1
SAGEMAKER_REGRESSION_ENDPOINT=housing-rf-endpoint
SAGEMAKER_CLASSIFICATION_ENDPOINT=bank-lr-endpoint
